# =============================================================================
# DC Workbench — Environment Configuration
# Copy this file to .env and fill in values before running.
# =============================================================================

# ── Session & Auth ────────────────────────────────────────────────────────────
# Session signing key — min 32 chars, must stay stable across deploys (re-signs all sessions).
# REQUIRED. Generate: openssl rand -hex 32
WORKBENCH_SESSION_SECRET=

# Bootstrap admin on empty DB. Min 4 chars. No public sign-up.
# Additional users: sidebar Admin → Users, or: npm run add-user -- <user> <pass>
WORKBENCH_ADMIN_PASSWORD=
WORKBENCH_ADMIN_USER=admin

# ── Database ──────────────────────────────────────────────────────────────────
# Default: ./data/workbench.db (or /app/data/workbench.db in Docker)
# SQLITE_PATH=/app/data/workbench.db

# ── OpenRouter (LLM) ──────────────────────────────────────────────────────────
# Operator pay-as-you-go key. Optional if all users use BYOK.
# OPENROUTER_API_KEY=

# Optional: shown in OpenRouter dashboard for monitoring
# OPENROUTER_HTTP_REFERER=https://your-domain.example
# OPENROUTER_APP_TITLE=DC Workbench
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# ── Routstr (decentralized AI via Bitcoin/Lightning) ──────────────────────────
# Operator-level Routstr key (sk-…). Optional — users can add their own in settings.
# Fund a session at https://routstr.com to get a key.
# ROUTSTR_API_KEY=
# ROUTSTR_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct

# 64 hex chars (32 bytes) — AES-256-GCM key for encrypting per-user BYOK in SQLite.
# Required in production if users store BYOK keys.
# Generate: openssl rand -hex 32
# WORKBENCH_BYOK_ENCRYPTION_KEY=

# ── Python Analytics Service ──────────────────────────────────────────────────
# URL of the Python FastAPI service. In Docker Compose this is automatic.
# For local dev without Docker, run: cd python && uvicorn main:app --port 8000
PYTHON_SERVICE_URL=http://localhost:8000

# ── FRED API (Federal Reserve data) ──────────────────────────────────────────
# Free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Required for Macro dashboard and FRED series in the workbench.
# FRED_API_KEY=

# Overnight report time (UTC hour, 0-23). Default: 2am UTC.
# REPORT_HOUR_UTC=2

# ── Litestream (SQLite backup) ────────────────────────────────────────────────
# Only required when running: docker compose --profile backup up -d
# Supports: AWS S3, Cloudflare R2, Backblaze B2, MinIO
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
# LITESTREAM_BUCKET=your-bucket-name
# LITESTREAM_REGION=us-east-1
# LITESTREAM_ENDPOINT=           # Leave blank for AWS S3; set for R2/B2/MinIO

# ── Next.js ───────────────────────────────────────────────────────────────────
# For reverse proxy sub-path deployments (e.g. /workbench). Usually blank.
NEXT_PUBLIC_BASE_PATH=
NODE_ENV=production
